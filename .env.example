# Copy to .env and fill with your values. Do not commit .env.

# Google Tag Manager
GTM_ID=GTM-XXXXXX

# Google Ads (Enhanced Conversions)
GOOGLE_ADS_ID=AW-XXXXXXXXX
GOOGLE_ADS_CONVERSION_LABEL=YYYYYYYYY

# OpenWeather Agro API (Agromonitoring)
OPENWEATHER_AGRO_API_KEY=your_api_key_here

# Google Maps (tarla çizimi için)
GOOGLE_MAPS_API_KEY=your_maps_key_here
